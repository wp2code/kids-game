# 听声音识物 - 环境变量配置
# 复制此文件为 .env 并填入你的密钥

# ── Supabase（主源，推荐配置）────────────────────────────
# 1. 登录 https://supabase.com/dashboard → 你的项目 → Settings → API
# 2. 复制 Project URL 和 anon public key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── 资源路由地址（可选）──────────────────────────────────
# 默认使用 Supabase Storage 公开地址
# 如需使用 CDN 或自定义域名，可在此覆盖
# 示例：https://cdn.example.com/sounds/
VITE_SOUNDS_BASE_URL=
# 示例：https://cdn.example.com/images/
VITE_IMAGES_BASE_URL=

# ── Freesound（声音降级，可选）───────────────────────────
# 获取地址：https://freesound.org/apiv2/apply/
VITE_FREESOUND_TOKEN=

# ── Pexels（图片降级，可选）──────────────────────────────
# 获取地址：https://www.pexels.com/api/
# 填入后自动启用真实照片，不填则使用 Emoji 图标
VITE_PEXELS_KEY=
